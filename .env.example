# PollGrid API keys — copy to .env (or use the in-app Settings tab, which writes
# this file for you). Every key is OPTIONAL: a missing key degrades its source
# gracefully, it never crashes the platform. The Settings tab validates each key
# live against its provider before saving.

# Census ACS demographics. Keyless works but is rate-limited/flaky under load.
# Free, instant: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Congress.gov legislation. REQUIRED to ingest any bills/legislation (no fallback).
# Free, instant: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# OpenFEC campaign finance. DEMO_KEY is used automatically if unset (throttled).
# Free, instant: https://api.open.fec.gov/developers/
FEC_API_KEY=

# BLS economic indicators (the fundamentals economic index). Keyless = 25 req/day.
# Free: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# --- Analyst LLM (all optional; local Ollama at localhost:11434 is tried first,
#     and every AI feature has a deterministic fallback when none is reachable) ---
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# AP Elections (paid, gated off in config.yaml by default — leave unset)
AP_ELECTIONS_API_KEY=
